{
  "name": "fake-news-detector",
  "version": "1.0.0",
  "description": "Fake News Detector – single port (FastAPI serves built React on :8000)",
  "scripts": {
    "start": "npm run build:frontend && npm run serve",
    "build:frontend": "cd frontend/veritas-dashboard-main && npm run build",
    "serve": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run serve:dev\" \"npm run frontend:dev\"",
    "serve:dev": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend:dev": "cd frontend/veritas-dashboard-main && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
